<Window x:Class="SilentPrintBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SilentPrintBridge.UI"
        mc:Ignorable="d"
        Title="SilentPrintBridge Control Panel" Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        Background="#F8F9FA">

    <Window.Resources>
        <!-- Professional Color Palette -->
        <!-- Primary: #2563EB (Blue) -->
        <!-- Success: #10B981 (Green) -->
        <!-- Danger: #EF4444 (Red) -->
        <!-- Warning: #F59E0B (Amber) -->
        <!-- Info: #3B82F6 (Light Blue) -->
        <!-- Purple: #8B5CF6 -->
        <!-- Gray: #6B7280 -->
        <!-- Background: #F8F9FA -->
        <!-- Surface: #FFFFFF -->
        <!-- Border: #E5E7EB -->

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#059669"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D97706"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PurpleButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ModernGroupBox" TargetType="GroupBox">
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <TextBlock Text="{TemplateBinding Header}"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="#1F2937"
                                          Margin="0,0,0,16"/>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Clean Professional Header -->
        <Border Grid.Row="0" Background="#2563EB" Padding="24" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SilentPrintBridge" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Thermal Printer Control Panel" FontSize="13" Foreground="#DBEAFE" Margin="0,4,0,0"/>
                    <TextBlock Text="Developed by Khalil Hasanzade • github.com/hasanzadekhalil"
                              FontSize="11" Foreground="#BFDBFE" Margin="0,8,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1E40AF" CornerRadius="8" Padding="20,12">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" Text="Service Stopped" FontSize="14" FontWeight="SemiBold"
                                  Foreground="White" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="#EF4444"/>
                            <TextBlock x:Name="HealthText" Text="Not Healthy" FontSize="12" Foreground="#DBEAFE"
                                      Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Service Control Panel -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="16,0,16,16"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Service Control" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="StartButton" Content="▶ Start Service" Click="StartButton_Click"
                            Style="{StaticResource SuccessButton}" MinWidth="140"/>
                    <Button x:Name="StopButton" Content="⏹ Stop Service" Click="StopButton_Click"
                            Style="{StaticResource DangerButton}" MinWidth="140" IsEnabled="False"/>
                    <Button x:Name="RestartButton" Content="🔄 Restart" Click="RestartButton_Click"
                            Style="{StaticResource WarningButton}" MinWidth="140" IsEnabled="False"/>
                    <Button x:Name="TestPrintButton" Content="🖨 Test Print" Click="TestPrintButton_Click"
                            Style="{StaticResource PrimaryButton}" MinWidth="140"/>
                    <Button x:Name="InstallServiceButton" Content="⚙ Install Service" Click="InstallServiceButton_Click"
                            Style="{StaticResource PurpleButton}" MinWidth="140"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Tabs -->
        <TabControl Grid.Row="2" Margin="16,0,16,16" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,1,1,0"
                                        CornerRadius="6,6,0,0" Padding="20,12" Margin="2,0">
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#EFF6FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                    <Setter Property="Foreground" Value="#4B5563"/>
                </Style>
            </TabControl.Resources>

            <!-- Configuration Tab -->
            <TabItem Header="⚙ Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="12">
                        <GroupBox Header="Printer Settings" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Printer Name:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <ComboBox x:Name="PrinterComboBox" Grid.Row="0" Grid.Column="1"
                                         Style="{StaticResource ModernComboBox}"
                                         SelectionChanged="PrinterComboBox_SelectionChanged"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Receipt Width (mm):" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <TextBox x:Name="ReceiptWidthTextBox" Grid.Row="1" Grid.Column="1" Text="80"
                                        Style="{StaticResource ModernTextBox}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Auto Cut:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <CheckBox x:Name="AutoCutCheckBox" Grid.Row="2" Grid.Column="1"
                                         Content="Append cut command after print" VerticalAlignment="Center" Margin="8" FontSize="14"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Feed Before Cut:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <TextBox x:Name="FeedLinesTextBox" Grid.Row="3" Grid.Column="1" Text="3"
                                        Style="{StaticResource ModernTextBox}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Server Settings" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <TextBox x:Name="HostTextBox" Grid.Row="0" Grid.Column="1" Text="127.0.0.1"
                                        Style="{StaticResource ModernTextBox}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <TextBox x:Name="PortTextBox" Grid.Row="1" Grid.Column="1" Text="17878"
                                        Style="{StaticResource ModernTextBox}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Remote Access:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <CheckBox x:Name="RemoteAccessCheckBox" Grid.Row="2" Grid.Column="1"
                                         Content="Allow remote connections (0.0.0.0)" VerticalAlignment="Center" Margin="8" FontSize="14"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="API Key:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <CheckBox x:Name="RequireApiKeyCheckBox" Grid.Row="3" Grid.Column="1"
                                         Content="Require API key authentication" VerticalAlignment="Center" Margin="8" FontSize="14"
                                         Checked="RequireApiKeyCheckBox_Changed" Unchecked="RequireApiKeyCheckBox_Changed"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="API Key Value:" VerticalAlignment="Center" Margin="8" FontSize="14" Foreground="#374151"/>
                                <TextBox x:Name="ApiKeyTextBox" Grid.Row="4" Grid.Column="1" IsEnabled="False"
                                        Style="{StaticResource ModernTextBox}"/>
                            </Grid>
                        </GroupBox>

                        <Button x:Name="SaveConfigButton" Content="💾 Save Configuration" Click="SaveConfigButton_Click"
                               Style="{StaticResource SuccessButton}"
                               HorizontalAlignment="Center" MinWidth="250" Margin="20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Logs Tab -->
            <TabItem Header="📋 Logs">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="6" Margin="12">
                        <TextBox x:Name="LogTextBox"
                                IsReadOnly="True"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto"
                                FontFamily="Consolas"
                                FontSize="13"
                                Background="Transparent"
                                Foreground="#D4D4D4"
                                Padding="16"
                                BorderThickness="0"/>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
                        <Button Content="🗑 Clear Logs" Click="ClearLogsButton_Click"
                               Style="{StaticResource PrimaryButton}" Background="#6B7280"/>
                        <Button x:Name="RefreshLogsButton" Content="🔄 Refresh" Click="RefreshLogsButton_Click"
                               Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Debug Tab -->
            <TabItem Header="🔧 Debug">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <StackPanel Margin="12">
                        <GroupBox Header="Diagnostics" Style="{StaticResource ModernGroupBox}">
                            <StackPanel>
                                <Button Content="🔍 Check Service Health" Click="CheckHealthButton_Click"
                                       Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                <Button Content="📋 List All Printers" Click="ListPrintersButton_Click"
                                       Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                <Button Content="🌐 Test API Connection" Click="TestApiButton_Click"
                                       Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                <Button Content="📁 Open Log Folder" Click="OpenLogFolderButton_Click"
                                       Style="{StaticResource WarningButton}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Debug Output" Style="{StaticResource ModernGroupBox}">
                            <Border Background="#F9FAFB" CornerRadius="6" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="DebugTextBox"
                                        IsReadOnly="True"
                                        TextWrapping="Wrap"
                                        VerticalScrollBarVisibility="Auto"
                                        FontFamily="Consolas"
                                        FontSize="13"
                                        Background="Transparent"
                                        Foreground="#374151"
                                        BorderThickness="0"
                                        MinHeight="250"/>
                            </Border>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="ℹ About">
                <ScrollViewer Background="White">
                    <StackPanel Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="SilentPrintBridge" FontSize="32" FontWeight="Bold"
                                  Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Version 1.0.0" FontSize="16" Foreground="#6B7280"
                                  HorizontalAlignment="Center" Margin="0,0,0,32"/>

                        <Border Background="#F9FAFB" CornerRadius="8" Padding="24" Margin="0,0,0,24" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Developed by" FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                <TextBlock Text="Khalil Hasanzade" FontSize="18" FontWeight="SemiBold" Foreground="#1F2937"
                                          HorizontalAlignment="Center" Margin="0,4,0,4"/>
                                <TextBlock FontSize="14" HorizontalAlignment="Center">
                                    <Hyperlink NavigateUri="https://github.com/hasanzadekhalil" RequestNavigate="Hyperlink_RequestNavigate"
                                              Foreground="#2563EB">
                                        <Run Text="github.com/hasanzadekhalil"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Silent browser-to-printer communication service"
                                  HorizontalAlignment="Center" Margin="0,0,0,8" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="Supports ESC/POS thermal printers"
                                  HorizontalAlignment="Center" Margin="0,0,0,32" FontSize="14" Foreground="#6B7280"/>

                        <GroupBox Header="API Endpoints" Style="{StaticResource ModernGroupBox}" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock FontFamily="Consolas" Margin="0,4" FontSize="13" Foreground="#374151">
                                    <Run Text="Health: " FontWeight="SemiBold"/>
                                    <Run Text="GET http://127.0.0.1:17878/health"/>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas" Margin="0,4" FontSize="13" Foreground="#374151">
                                    <Run Text="Printers: " FontWeight="SemiBold"/>
                                    <Run Text="GET http://127.0.0.1:17878/printers"/>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas" Margin="0,4" FontSize="13" Foreground="#374151">
                                    <Run Text="Print: " FontWeight="SemiBold"/>
                                    <Run Text="POST http://127.0.0.1:17878/print"/>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas" Margin="0,4" FontSize="13" Foreground="#374151">
                                    <Run Text="Test: " FontWeight="SemiBold"/>
                                    <Run Text="POST http://127.0.0.1:17878/test-print"/>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <CheckBox x:Name="AutoStartCheckBox" Content="Start with Windows"
                                 Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="14"
                                 Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>
                        <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Minimize to system tray"
                                 Margin="0,8,0,0" HorizontalAlignment="Center" IsChecked="True" FontSize="14"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" Padding="16" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="StatusBarText" Text="Ready" VerticalAlignment="Center" FontSize="13" Foreground="#6B7280"/>
                <TextBlock x:Name="ApiUrlText" Text="API: http://127.0.0.1:17878"
                          HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#9CA3AF"/>
            </Grid>
        </Border>
    </Grid>
</Window>
