<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>..\..\logo.ico</ApplicationIcon>
    <BrandingVariant Condition="'$(BrandingVariant)'==''">Developer</BrandingVariant>
  </PropertyGroup>

  <PropertyGroup Condition="'$(BrandingVariant)'=='Customer'">
    <DefineConstants>$(DefineConstants);CUSTOMER_BRANDING</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(BrandingVariant)'!='Customer'">
    <DefineConstants>$(DefineConstants);DEVELOPER_BRANDING</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="1.1.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SilentPrintBridge\SilentPrintBridge.csproj" />
  </ItemGroup>

</Project>
